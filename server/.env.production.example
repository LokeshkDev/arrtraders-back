NODE_ENV=production
PORT=5000

# Public URLs
# Use your real domain, for example https://arrahmantraders.com.
CLIENT_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Security
JWT_SECRET=replace-with-a-long-random-secret
ENFORCE_APP_CHECK=true

# Firebase Admin
# Prefer JSON in production so no local key file is required.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace-me"}

# Cloudflare R2
R2_ENDPOINT=https://replace-me.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_NAME=replace-me
R2_PUBLIC_URL=https://replace-me.r2.dev

# MySQL
MYSQL_HOST=replace-with-db-host
MYSQL_USER=replace-with-db-user
MYSQL_PASSWORD=replace-with-db-password
MYSQL_DATABASE=replace-with-db-name

# Cashfree Payment Gateway
CASHFREE_ENV=production
CASHFREE_API_VERSION=2025-01-01
CASHFREE_CLIENT_ID=replace-with-production-client-id
CASHFREE_CLIENT_SECRET=replace-with-production-client-secret
# Optional: add only after creating a webhook route.
# CASHFREE_NOTIFY_URL=https://your-domain.com/api/orders/cashfree/webhook
